\n      border-bottom: 0.5px solid var(--border);\r\n      gap: 12px;\r\n    }\r\n    .reward-row:last-child { border-bottom: none; }\r\n    .rr-condition {\r\n      font-family: var(--mono);\r\n      font-size: 10px;\r\n      color: var(--text-dim);\r\n      flex: 1;\r\n    }\r\n    .rr-val {\r\n      font-family: var(--mono);\r\n      font-size: 12px;\r\n      font-weight: 700;\r\n      width: 60px;\r\n      text-align: right;\r\n      flex-shrink: 0;\r\n    }\r\n    .rr-bar {\r\n      width: 80px;\r\n      height: 4px;\r\n      background: rgba(61,159,255,0.08);\r\n      flex-shrink: 0;\r\n      position: relative;\r\n    }\r\n    .rr-bar-fill {\r\n      position: absolute;\r\n      top: 0; bottom: 0;\r\n      left: 0;\r\n      width: var(--w);\r\n      background: var(--c);\r\n    }\r\n\r\n    /* ══════════════════════════════════════════\r\n       PPO SECTION\r\n    ══════════════════════════════════════════ */\r\n    .ppo-grid {\r\n      display: grid;\r\n      grid-template-columns: 1fr 1fr;\r\n      gap: 2rem;\r\n      align-items: start;\r\n    }\r\n    .ppo-params {\r\n      display: flex;\r\n      flex-direction: column;\r\n      gap: 1px;\r\n      background: var(--border);\r\n      border: 0.5px solid var(--border);\r\n    }\r\n    .ppo-param-row {\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: space-between;\r\n      padding: 0.65rem 1.25rem;\r\n      background: var(--bg2);\r\n      gap: 12px;\r\n    }\r\n    .pp-key {\r\n      font-family: var(--mono);\r\n      font-size: 10px;\r\n      color: var(--text-dim);\r\n      letter-spacing: 0.08em;\r\n    }\r\n    .pp-val {\r\n      font-family: var(--mono);\r\n      font-size: 11px;\r\n      font-weight: 700;\r\n      color: var(--blue);\r\n    }\r\n    .pp-desc {\r\n      font-family: var(--mono);\r\n      font-size: 9px;\r\n      color: var(--text-dim);\r\n      text-align: right;\r\n    }\r\n\r\n    /* ══════════════════════════════════════════\r\n       SCIENTIFIC JUSTIFICATION CARDS\r\n    ══════════════════════════════════════════ */\r\n    .justify-grid {\r\n      display: grid;\r\n      grid-template-columns: repeat(3, 1fr);\r\n      gap: 1px;\r\n      background: var(--border);\r\n      border: 0.5px solid var(--border);\r\n    }\r\n    .justify-card {\r\n      background: var(--bg2);\r\n      padding: 1.75rem 1.5rem;\r\n      position: relative;\r\n      overflow: hidden;\r\n    }\r\n    .justify-card::before {\r\n      content: '';\r\n      position: absolute;\r\n      top: 0; left: 0; right: 0;\r\n      height: 2px;\r\n      background: var(--ac);\r\n    }\r\n    .justify-num {\r\n      font-family: var(--mono);\r\n      font-size: 2rem;\r\n      font-weight: 800;\r\n      color: rgba(61,159,255,0.12);\r\n      line-height: 1;\r\n      margin-bottom: 0.75rem;\r\n    }\r\n    .justify-title {\r\n      font-size: 0.95rem;\r\n      font-weight: 700;\r\n      color: #eaf4ff;\r\n      margin-bottom: 0.6rem;\r\n    }\r\n    .justify-body {\r\n      font-family: var(--mono);\r\n      font-size: 10px;\r\n      color: var(--text-dim);\r\n      line-height: 1.9;\r\n    }\r\n    .justify-body strong { color: var(--blue); }\r\n\r\n    /* ══════════════════════════════════════════\r\n       RESPONSIVE\r\n    ══════════════════════════════════════════ */\r\n    @media (max-width: 900px) {\r\n      .why-grid     { grid-template-columns: 1fr; }\r\n      .arch-grid    { grid-template-columns: 1fr; }\r\n      .energy-grid  { grid-template-columns: 1fr; }\r\n      .reward-grid  { grid-template-columns: 1fr; }\r\n      .ppo-grid     { grid-template-columns: 1fr; }\r\n      .justify-grid { grid-template-columns: 1fr; }\r\n      .sci-header   { flex-direction: column; }\r\n      .sci-section  { padding: 2rem 1.5rem; }\r\n    }\r\n  </style>\r\n</head>\r\n<body>\r\n\r\n<canvas id=\"stars-canvas\"></canvas>\r\n\r\n<div class=\"page\">\r\n\r\n  <!-- ══ NAV ══ -->\r\n  <nav class=\"nav\">\r\n    <a class=\"nav-logo\" href=\"index.html\">\r\n      <div class=\"nav-logo-dot\"></div>\r\n      PROTEINFOLD-RL\r\n    </a>\r\n    <ul class=\"nav-links\">\r\n      <a href=\"index.html\"             >Home</a>\r\n      <a href=\"dashboard.html\"         >Dashboard</a>\r\n      <a href=\"demo.html\"              >Live Demo</a>\r\n      <a href=\"science.html\" class=\"active\">Science</a>\r\n      <a href=\"compare.html\"           >Compare</a>\r\n    </ul>\r\n    <div class=\"nav-right\">CHECKPOINT-07 &nbsp;·&nbsp; OPEN INNOVATION</div>\r\n  </nav>\r\n\r\n  <!-- ══ PAGE HEADER ══ -->\r\n  <div class=\"sci-header\">\r\n    <div>\r\n      <div class=\"sci-eyebrow\">Architecture · Physics · Algorithms</div>\r\n      <div class=\"sci-title\">The Science</div>\r\n      <div class=\"sci-subtitle\">\r\n        How ProteinFold-RL works — from atoms to actions to learning\r\n      </div>\r\n    </div>\r\n    <div class=\"sci-header-right\">\r\n      <div class=\"sci-tag\">GNN + PPO-clip</div>\r\n      <div class=\"sci-tag\">NeRF kinematics</div>\r\n      <div class=\"sci-tag\">Lennard-Jones potential</div>\r\n    </div>\r\n  </div>\r\n\r\n  <!-- ══ TICKER ══ -->\r\n  <div class=\"ticker\">\r\n    <div class=\"ticker-track\" id=\"ticker-track\"></div>\r\n  </div>\r\n\r\n  <!-- ══════════════════════════════════════════\r\n       SECTION 1 — WHY RL\r\n  ══════════════════════════════════════════ -->\r\n  <section class=\"sci-section\">\r\n    <div class=\"section-label\">01 — the problem · why reinforcement learning</div>\r\n    <div class=\"why-grid\">\r\n      <div class=\"why-text\">\r\n        <div class=\"why-heading\">\r\n          AlphaFold knows the answer.<br>\r\n          It cannot explain the path.\r\n        </div>\r\n        <p class=\"why-para\">\r\n          AlphaFold2 achieved a scientific breakthrough — predicting\r\n          the final 3D structure of a protein from its amino acid sequence\r\n          with near-experimental accuracy. It won the Nobel Prize in 2024.\r\n        </p>\r\n        <p class=\"why-para\">\r\n          But AlphaFold is completely silent about\r\n          <strong>the folding pathway</strong> — the sequence of physical\r\n          conformational changes a protein undergoes as it folds.\r\n          And the pathway is where disease lives.\r\n        </p>\r\n        <p class=\"why-para\">\r\n          <em>Alzheimer's, Parkinson's, Type 2 Diabetes</em> — all caused\r\n          by proteins that misfolded during the journey, not at the\r\n          destination. No dataset of correct folding pathways exists.\r\n          <strong>Physics is the only teacher.</strong>\r\n        </p>\r\n        <p class=\"why-para\">\r\n          Reinforcement learning is the only framework honest enough\r\n          to learn from a physics-based reward signal without requiring\r\n          labelled examples of correct folding trajectories.\r\n        </p>\r\n      </div>\r\n      <div class=\"why-cards\">\r\n        <div class=\"why-card\">\r\n          <div class=\"why-card-icon\">01</div>\r\n          <div class=\"why-card-body\">\r\n            <div class=\"why-card-title\">No labelled data exists</div>\r\n            <div class=\"why-card-desc\">\r\n              Supervised learning requires (input, correct output) pairs.\r\n              No database of correct folding pathways exists at atomic\r\n              resolution. RL learns without labels — reward is physics.\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"why-card\">\r\n          <div class=\"why-card-icon\">02</div>\r\n          <div class=\"why-card-body\">\r\n            <div class=\"why-card-title\">Sequential decisions</div>\r\n            <div class=\"why-card-desc\">\r\n              Folding is a sequential process — each dihedral angle\r\n              adjustment depends on the current conformation. RL\r\n              naturally models sequential decision-making over time.\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"why-card\">\r\n          <div class=\"why-card-icon\">03</div>\r\n          <div class=\"why-card-body\">\r\n            <div class=\"why-card-title\">Physics as reward</div>\r\n            <div class=\"why-card-desc\">\r\n              The Lennard-Jones energy function provides a\r\n              differentiable, physics-grounded reward signal. Lower\r\n              energy = more stable structure = better fold.\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"why-card\">\r\n          <div class=\"why-card-icon\">04</div>\r\n          <div class=\"why-card-body\">\r\n            <div class=\"why-card-title\">Exploration of pathways</div>\r\n            <div class=\"why-card-desc\">\r\n              The PPO entropy bonus encourages exploration of novel\r\n              folding pathways — not just greedy energy minimisation.\r\n              This mirrors how proteins actually explore conformational space.\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </section>\r\n\r\n  <!-- ══════════════════════════════════════════\r\n       SECTION 2 — RL LOOP DIAGRAM\r\n  ══════════════════════════════════════════ -->\r\n  <section class=\"sci-section\">\r\n    <div class=\"section-label\">02 — RL loop · state → action → reward → policy</div>\r\n    <div class=\"rl-diagram-wrap\">\r\n      <div class=\"rl-diagram-label\">Full RL loop — ProteinFold-RL</div>\r\n      <svg width=\"100%\" viewBox=\"0 0 900 320\"\r\n           fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"\r\n           style=\"min-width:700px;\">\r\n\r\n        <!-- STATE box -->\r\n        <rect x=\"20\" y=\"100\" width=\"160\" height=\"120\"\r\n              fill=\"rgba(61,159,255,0.06)\"\r\n              stroke=\"rgba(61,159,255,0.3)\" stroke-width=\"0.5\"/>\r\n        <text x=\"100\" y=\"124\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(61,159,255,0.5)\" letter-spacing=\"2\">STATE</text>\r\n        <text x=\"100\" y=\"148\" text-anchor=\"middle\"\r\n              font-family=\"Syne,sans-serif\" font-size=\"13\"\r\n              fill=\"#eaf4ff\" font-weight=\"800\">Protein Graph</text>\r\n        <text x=\"100\" y=\"166\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(180,210,240,0.45)\">Nodes [N, 23]</text>\r\n        <text x=\"100\" y=\"182\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(180,210,240,0.45)\">Edges [E, 4]</text>\r\n        <text x=\"100\" y=\"198\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(180,210,240,0.45)\">8Å contacts</text>\r\n\r\n        <!-- Arrow STATE → POLICY -->\r\n        <line x1=\"180\" y1=\"160\" x2=\"238\" y2=\"160\"\r\n              stroke=\"rgba(61,159,255,0.5)\" stroke-width=\"1\"\r\n              marker-end=\"url(#arr)\"/>\r\n\r\n        <!-- POLICY box -->\r\n        <rect x=\"240\" y=\"80\" width=\"160\" height=\"160\"\r\n              fill=\"rgba(255,179,71,0.06)\"\r\n              stroke=\"rgba(255,179,71,0.35)\" stroke-width=\"0.5\"/>\r\n        <text x=\"320\" y=\"104\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(255,179,71,0.5)\" letter-spacing=\"2\">POLICY</text>\r\n        <text x=\"320\" y=\"128\" text-anchor=\"middle\"\r\n              font-family=\"Syne,sans-serif\" font-size=\"13\"\r\n              fill=\"#eaf4ff\" font-weight=\"800\">GNN + PPO</text>\r\n        <text x=\"320\" y=\"148\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(180,210,240,0.45)\">NodeEncoder</text>\r\n        <text x=\"320\" y=\"164\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(255,179,71,0.7)\">4× MPNN layers</text>\r\n        <text x=\"320\" y=\"180\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(180,210,240,0.45)\">256-dim global</text>\r\n        <text x=\"320\" y=\"196\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(180,210,240,0.45)\">policy head</text>\r\n        <text x=\"320\" y=\"212\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(180,210,240,0.45)\">value head</text>\r\n\r\n        <!-- Arrow POLICY → ACTION -->\r\n        <line x1=\"400\" y1=\"160\" x2=\"458\" y2=\"160\"\r\n              stroke=\"rgba(255,179,71,0.5)\" stroke-width=\"1\"\r\n              marker-end=\"url(#arr2)\"/>\r\n\r\n        <!-- ACTION box -->\r\n        <rect x=\"460\" y=\"100\" width=\"160\" height=\"120\"\r\n              fill=\"rgba(0,212,170,0.06)\"\r\n              stroke=\"rgba(0,212,170,0.3)\" stroke-width=\"0.5\"/>\r\n        <text x=\"540\" y=\"124\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(0,212,170,0.5)\" letter-spacing=\"2\">ACTION</text>\r\n        <text x=\"540\" y=\"148\" text-anchor=\"middle\"\r\n              font-family=\"Syne,sans-serif\" font-size=\"13\"\r\n              fill=\"#eaf4ff\" font-weight=\"800\">Dihedral Δ</text>\r\n        <text x=\"540\" y=\"166\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(180,210,240,0.45)\">N × 2 × 12</text>\r\n        <text x=\"540\" y=\"182\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(180,210,240,0.45)\">φ/ψ ± 30°</text>\r\n        <text x=\"540\" y=\"198\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(180,210,240,0.45)\">NeRF chain</text>\r\n\r\n        <!-- Arrow ACTION → REWARD -->\r\n        <line x1=\"620\" y1=\"160\" x2=\"678\" y2=\"160\"\r\n              stroke=\"rgba(0,212,170,0.5)\" stroke-width=\"1\"\r\n              marker-end=\"url(#arr3)\"/>\r\n\r\n        <!-- REWARD box -->\r\n        <rect x=\"680\" y=\"100\" width=\"160\" height=\"120\"\r\n              fill=\"rgba(255,95,95,0.06)\"\r\n              stroke=\"rgba(255,95,95,0.3)\" stroke-width=\"0.5\"/>\r\n        <text x=\"760\" y=\"124\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(255,95,95,0.5)\" letter-spacing=\"2\">REWARD</text>\r\n        <text x=\"760\" y=\"148\" text-anchor=\"middle\"\r\n              font-family=\"Syne,sans-serif\" font-size=\"13\"\r\n              fill=\"#eaf4ff\" font-weight=\"800\">Physics</text>\r\n        <text x=\"760\" y=\"166\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(0,212,170,0.7)\">+8.0 big drop</text>\r\n        <text x=\"760\" y=\"182\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(61,159,255,0.7)\">+15.0 RMSD&lt;2Å</text>\r\n        <text x=\"760\" y=\"198\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n              fill=\"rgba(255,95,95,0.7)\">−2.0 clash</text>\r\n\r\n        <!-- Feedback arrow REWARD → STATE (curved bottom) -->\r\n        <path d=\"M760 220 Q760 280 440 280 Q120 280 100 220\"\r\n              stroke=\"rgba(61,159,255,0.25)\" stroke-width=\"1\"\r\n              fill=\"none\" stroke-dasharray=\"5 3\"\r\n              marker-end=\"url(#arr)\"/>\r\n        <text x=\"440\" y=\"298\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"8\"\r\n              fill=\"rgba(61,159,255,0.3)\" letter-spacing=\"2\">\r\n          NEXT STATE — UPDATED CONFORMATION\r\n        </text>\r\n\r\n        <!-- PPO update arrow (top) -->\r\n        <path d=\"M760 100 Q760 40 540 40 Q320 40 320 80\"\r\n              stroke=\"rgba(255,179,71,0.2)\" stroke-width=\"1\"\r\n              fill=\"none\" stroke-dasharray=\"4 3\"\r\n              marker-end=\"url(#arr2)\"/>\r\n        <text x=\"540\" y=\"28\" text-anchor=\"middle\"\r\n              font-family=\"Space Mono,monospace\" font-size=\"8\"\r\n              fill=\"rgba(255,179,71,0.35)\" letter-spacing=\"2\">\r\n          PPO UPDATE — GAE ADVANTAGE\r\n        </text>\r\n\r\n        <!-- Arrow markers -->\r\n        <defs>\r\n          <marker id=\"arr\" viewBox=\"0 0 10 10\" refX=\"8\" refY=\"5\"\r\n                  markerWidth=\"5\" markerHeight=\"5\" orient=\"auto\">\r\n            <path d=\"M2 1L8 5L2 9\" fill=\"none\"\r\n                  stroke=\"rgba(61,159,255,0.5)\" stroke-width=\"1.5\"\r\n                  stroke-linecap=\"round\"/>\r\n          </marker>\r\n          <marker id=\"arr2\" viewBox=\"0 0 10 10\" refX=\"8\" refY=\"5\"\r\n                  markerWidth=\"5\" markerHeight=\"5\" orient=\"auto\">\r\n            <path d=\"M2 1L8 5L2 9\" fill=\"none\"\r\n                  stroke=\"rgba(255,179,71,0.5)\" stroke-width=\"1.5\"\r\n                  stroke-linecap=\"round\"/>\r\n          </marker>\r\n          <marker id=\"arr3\" viewBox=\"0 0 10 10\" refX=\"8\" refY=\"5\"\r\n                  markerWidth=\"5\" markerHeight=\"5\" orient=\"auto\">\r\n            <path d=\"M2 1L8 5L2 9\" fill=\"none\"\r\n                  stroke=\"rgba(0,212,170,0.5)\" stroke-width=\"1.5\"\r\n                  stroke-linecap=\"round\"/>\r\n          </marker>\r\n        </defs>\r\n\r\n      </svg>\r\n    </div>\r\n  </section>\r\n\r\n  <!-- ══════════════════════════════════════════\r\n       SECTION 3 — GNN ARCHITECTURE\r\n  ══════════════════════════════════════════ -->\r\n  <section class=\"sci-section\">\r\n    <div class=\"section-label\">03 — model architecture · graph neural network</div>\r\n    <div class=\"arch-grid\">\r\n\r\n      <!-- Visual: GNN layers diagram -->\r\n      <div class=\"arch-visual\">\r\n        <div class=\"rl-diagram-label\">GNN forward pass</div>\r\n        <svg width=\"100%\" viewBox=\"0 0 380 480\"\r\n             fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\r\n\r\n          <!-- Input -->\r\n          <rect x=\"60\" y=\"10\" width=\"260\" height=\"40\" rx=\"2\"\r\n                fill=\"rgba(61,159,255,0.08)\"\r\n                stroke=\"rgba(61,159,255,0.25)\" stroke-width=\"0.5\"/>\r\n          <text x=\"190\" y=\"28\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(61,159,255,0.6)\" letter-spacing=\"1\">INPUT</text>\r\n          <text x=\"190\" y=\"42\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(180,210,240,0.5)\">\r\n            protein graph · nodes [N,23] · edges [E,4]\r\n          </text>\r\n\r\n          <line x1=\"190\" y1=\"50\" x2=\"190\" y2=\"68\"\r\n                stroke=\"rgba(61,159,255,0.3)\" stroke-width=\"0.5\"\r\n                marker-end=\"url(#ga)\"/>\r\n\r\n          <!-- Node encoder -->\r\n          <rect x=\"80\" y=\"70\" width=\"220\" height=\"36\" rx=\"2\"\r\n                fill=\"rgba(61,159,255,0.1)\"\r\n                stroke=\"rgba(61,159,255,0.3)\" stroke-width=\"0.5\"/>\r\n          <text x=\"190\" y=\"86\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(61,159,255,0.7)\" letter-spacing=\"1\">NODE ENCODER</text>\r\n          <text x=\"190\" y=\"100\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(180,210,240,0.45)\">Linear(23→128) → GELU → Linear(128→128)</text>\r\n\r\n          <line x1=\"190\" y1=\"106\" x2=\"190\" y2=\"124\"\r\n                stroke=\"rgba(61,159,255,0.3)\" stroke-width=\"0.5\"\r\n                marker-end=\"url(#ga)\"/>\r\n\r\n          <!-- Edge encoder -->\r\n          <rect x=\"80\" y=\"126\" width=\"220\" height=\"36\" rx=\"2\"\r\n                fill=\"rgba(61,159,255,0.08)\"\r\n                stroke=\"rgba(61,159,255,0.2)\" stroke-width=\"0.5\"/>\r\n          <text x=\"190\" y=\"142\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(61,159,255,0.6)\" letter-spacing=\"1\">EDGE ENCODER</text>\r\n          <text x=\"190\" y=\"156\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(180,210,240,0.45)\">Linear(4→64) → GELU → Linear(64→64)</text>\r\n\r\n          <line x1=\"190\" y1=\"162\" x2=\"190\" y2=\"180\"\r\n                stroke=\"rgba(255,179,71,0.4)\" stroke-width=\"0.5\"\r\n                marker-end=\"url(#gb)\"/>\r\n\r\n          <!-- MPNN 1 -->\r\n          <rect x=\"40\" y=\"182\" width=\"300\" height=\"32\" rx=\"2\"\r\n                fill=\"rgba(255,179,71,0.08)\"\r\n                stroke=\"rgba(255,179,71,0.3)\" stroke-width=\"0.5\"/>\r\n          <text x=\"190\" y=\"196\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(255,179,71,0.7)\" letter-spacing=\"1\">MPNN LAYER 1</text>\r\n          <text x=\"190\" y=\"208\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(180,210,240,0.4)\">message passing · 128-dim · edge-conditioned</text>\r\n\r\n          <line x1=\"190\" y1=\"214\" x2=\"190\" y2=\"228\"\r\n                stroke=\"rgba(255,179,71,0.4)\" stroke-width=\"0.5\"\r\n                marker-end=\"url(#gb)\"/>\r\n\r\n          <!-- MPNN 2 -->\r\n          <rect x=\"40\" y=\"230\" width=\"300\" height=\"32\" rx=\"2\"\r\n                fill=\"rgba(255,179,71,0.08)\"\r\n                stroke=\"rgba(255,179,71,0.3)\" stroke-width=\"0.5\"/>\r\n          <text x=\"190\" y=\"244\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(255,179,71,0.7)\" letter-spacing=\"1\">MPNN LAYER 2</text>\r\n          <text x=\"190\" y=\"256\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(180,210,240,0.4)\">message passing · 128-dim · edge-conditioned</text>\r\n\r\n          <line x1=\"190\" y1=\"262\" x2=\"190\" y2=\"276\"\r\n                stroke=\"rgba(255,179,71,0.4)\" stroke-width=\"0.5\"\r\n                marker-end=\"url(#gb)\"/>\r\n\r\n          <!-- MPNN 3+4 collapsed -->\r\n          <rect x=\"40\" y=\"278\" width=\"300\" height=\"32\" rx=\"2\"\r\n                fill=\"rgba(255,179,71,0.08)\"\r\n                stroke=\"rgba(255,179,71,0.3)\" stroke-width=\"0.5\"/>\r\n          <text x=\"190\" y=\"292\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(255,179,71,0.7)\" letter-spacing=\"1\">MPNN LAYERS 3 + 4</text>\r\n          <text x=\"190\" y=\"306\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(180,210,240,0.4)\">same · total 4 layers · residual connections</text>\r\n\r\n          <line x1=\"190\" y1=\"310\" x2=\"190\" y2=\"328\"\r\n                stroke=\"rgba(61,159,255,0.4)\" stroke-width=\"0.5\"\r\n                marker-end=\"url(#ga)\"/>\r\n\r\n          <!-- Global pool -->\r\n          <rect x=\"80\" y=\"330\" width=\"220\" height=\"32\" rx=\"2\"\r\n                fill=\"rgba(61,159,255,0.1)\"\r\n                stroke=\"rgba(61,159,255,0.3)\" stroke-width=\"0.5\"/>\r\n          <text x=\"190\" y=\"344\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(61,159,255,0.7)\" letter-spacing=\"1\">GLOBAL MEAN POOL</text>\r\n          <text x=\"190\" y=\"358\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(180,210,240,0.45)\">128-dim → Linear(128→256) → GELU</text>\r\n\r\n          <line x1=\"120\" y1=\"362\" x2=\"80\"  y2=\"400\"\r\n                stroke=\"rgba(0,212,170,0.4)\" stroke-width=\"0.5\"\r\n                marker-end=\"url(#gc)\"/>\r\n          <line x1=\"260\" y1=\"362\" x2=\"300\" y2=\"400\"\r\n                stroke=\"rgba(255,95,95,0.4)\" stroke-width=\"0.5\"\r\n                marker-end=\"url(#gd)\"/>\r\n\r\n          <!-- Policy head -->\r\n          <rect x=\"10\" y=\"402\" width=\"160\" height=\"36\" rx=\"2\"\r\n                fill=\"rgba(0,212,170,0.08)\"\r\n                stroke=\"rgba(0,212,170,0.25)\" stroke-width=\"0.5\"/>\r\n          <text x=\"90\" y=\"418\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(0,212,170,0.7)\" letter-spacing=\"1\">POLICY HEAD</text>\r\n          <text x=\"90\" y=\"432\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(180,210,240,0.45)\">Linear(256→action_dim)</text>\r\n\r\n          <!-- Value head -->\r\n          <rect x=\"210\" y=\"402\" width=\"160\" height=\"36\" rx=\"2\"\r\n                fill=\"rgba(255,95,95,0.08)\"\r\n                stroke=\"rgba(255,95,95,0.25)\" stroke-width=\"0.5\"/>\r\n          <text x=\"290\" y=\"418\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(255,95,95,0.7)\" letter-spacing=\"1\">VALUE HEAD</text>\r\n          <text x=\"290\" y=\"432\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"9\"\r\n                fill=\"rgba(180,210,240,0.45)\">Linear(256→128→1)</text>\r\n\r\n          <!-- Output labels -->\r\n          <text x=\"90\" y=\"458\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"8\"\r\n                fill=\"rgba(0,212,170,0.5)\">action logits</text>\r\n          <text x=\"290\" y=\"458\" text-anchor=\"middle\"\r\n                font-family=\"Space Mono,monospace\" font-size=\"8\"\r\n                fill=\"rgba(255,95,95,0.5)\">state value V(s)</text>\r\n\r\n          <defs>\r\n            <marker id=\"ga\" viewBox=\"0 0 10 10\" refX=\"8\" refY=\"5\"\r\n                    markerWidth=\"4\" markerHeight=\"4\" orient=\"auto\">\r\n              <path d=\"M2 1L8 5L2 9\" fill=\"none\"\r\n                    stroke=\"rgba(61,159,255,0.5)\" stroke-width=\"1.5\"\r\n                    stroke-linecap=\"round\"/>\r\n            </marker>\r\n            <marker id=\"gb\" viewBox=\"0 0 10 10\" refX=\"8\" refY=\"5\"\r\n                    markerWidth=\"4\" markerHeight=\"4\" orient=\"auto\">\r\n              <path d=\"M2 1L8 5L2 9\" fill=\"none\"\r\n                    stroke=\"rgba(255,179,71,0.5)\" stroke-width=\"1.5\"\r\n                    stroke-linecap=\"round\"/>\r\n            </marker>\r\n            <marker id=\"gc\" viewBox=\"0 0 10 10\" refX=\"8\" refY=\"5\"\r\n                    markerWidth=\"4\" markerHeight=\"4\" orient=\"auto\">\r\n              <path d=\"M2 1L8 5L2 9\" fill=\"none\"\r\n                    stroke=\"rgba(0,212,170,0.5)\" stroke-width=\"1.5\"\r\n                    stroke-linecap=\"round\"/>\r\n            </marker>\r\n            <marker id=\"gd\" viewBox=\"0 0 10 10\" refX=\"8\" refY=\"5\"\r\n                    markerWidth=\"4\" markerHeight=\"4\" orient=\"auto\">\r\n              <path d=\"M2 1L8 5L2 9\" fill=\"none\"\r\n                    stroke=\"rgba(255,95,95,0.5)\" stroke-width=\"1.5\"\r\n                    stroke-linecap=\"round\"/>\r\n            </marker>\r\n          </defs>\r\n        </svg>\r\n      </div>\r\n\r\n      <!-- Text explanation -->\r\n      <div class=\"arch-text\">\r\n        <div class=\"arch-heading\">Graph Neural Network Policy</div>\r\n        <p class=\"arch-para\">\r\n          The protein is represented as a <strong>molecular graph</strong>\r\n          where each residue is a node and spatial contacts within\r\n          <em>8 Angstroms</em> are edges. This preserves the physical\r\n          topology of the molecule — unlike flat feature vectors.\r\n        </p>\r\n        <p class=\"arch-para\">\r\n          <strong>Message passing</strong> allows each residue to\r\n          aggregate information from its spatial neighbours over\r\n          4 rounds — capturing both local secondary structure and\r\n          global fold topology simultaneously.\r\n        </p>\r\n        <p class=\"arch-para\">\r\n          The <em>global mean pool</em> compresses the entire protein\r\n          into a single 256-dimensional vector — the \"state embedding\"\r\n          used by both the policy and value heads.\r\n        </p>\r\n\r\n        <table class=\"arch-table\">\r\n          <tr>\r\n            <td>Node input</td>\r\n            <td>20-dim AA one-hot + 3-dim Cα coords = [N, 23]</td>\r\n          </tr>\r\n          <tr>\r\n            <td>Edge input</td>\r\n            <td>distance + direction + peptide flag = [E, 4]</td>\r\n          </tr>\r\n          <tr>\r\n            <td>Hidden dim</td>\r\n            <td>128 node · 64 edge · 256 global</td>\r\n          </tr>\r\n          <tr>\r\n            <td>Layers</td>\r\n            <td>4× MPNN with edge-conditioned messages</td>\r\n          </tr>\r\n          <tr>\r\n            <td>Activation</td>\r\n            <td>GELU throughout</td>\r\n          </tr>\r\n          <tr>\r\n            <td>Init</td>\r\n            <td>Orthogonal weights · gain=0.01</td>\r\n          </tr>\r\n          <tr>\r\n            <td>Policy out</td>\r\n            <td>logits [1, N×2×12] → Categorical dist</td>\r\n          </tr>\r\n          <tr>\r\n            <td>Value out</td>\r\n            <td>scalar V(s) for GAE advantage estimation</td>\r\n          </tr>\r\n        </table>\r\n      </div>\r\n\r\n    </div>\r\n  </section>\r\n\r\n  <!-- ══════════════════════════════════════════\r\n       SECTION 4 — ENERGY + REWARD\r\n  ══════════════════════════════════════════ -->\r\n  <section class=\"sci-section\">\r\n    <div class=\"section-label\">04 — energy function · physics-based reward signal</div>\r\n    <div class=\"energy-grid\">\r\n\r\n      <div>\r\n        <div class=\"arch-heading\" style=\"margin-bottom:1.25rem;\">\r\n          The Physics Teacher\r\n        </div>\r\n        <p class=\"arch-para\">\r\n          The reward signal comes entirely from a\r\n          <strong>coarse-grained physics potential</strong> —\r\n          no human labels, no expert demonstrations.\r\n          This is justified by its use in MARTINI coarse-grained models,\r\n          published in <em>Nature Methods</em>.\r\n        </p>\r\n\r\n        <div class=\"eq-block\">\r\n          <div class=\"eq-label\">Lennard-Jones potential (pairwise)</div>\r\n          <div class=\"eq-formula\">\r\n            E_LJ = 4ε [ (σ/r)¹² − (σ/r)⁶ ]\r\n          </div>\r\n          <div class=\"eq-desc\">\r\n            <span>r</span> = Cα–Cα distance ·\r\n            <span>ε</span> = well depth ·\r\n            <span>σ</span> = collision diameter<br>\r\n            Repulsion dominates at short range · attraction at medium range\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"eq-block\" style=\"border-left-color:var(--teal);\">\r\n          <div class=\"eq-label\">Torsion energy (Ramachandran)</div>\r\n          <div class=\"eq-formula\">\r\n            E_tor = Σ k[1 + cos(nφ − δ)]\r\n          </div>\r\n          <div class=\"eq-desc\">\r\n            <span>φ, ψ</span> = backbone dihedral angles ·\r\n            <span>n</span> = periodicity ·\r\n            <span>δ</span> = phase<br>\r\n            Penalises sterically forbidden Ramachandran regions\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"eq-block\" style=\"border-left-color:var(--amber);\">\r\n          <div class=\"eq-label\">Total energy</div>\r\n          <div class=\"eq-formula\">\r\n            E_total = E_LJ + E_torsion\r\n          </div>\r\n          <div class=\"eq-desc\">\r\n            Computed at every step · delta used as reward signal ·\r\n            <span>lower = more stable = better fold</span>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- Reward table -->\r\n      <div>\r\n        <div class=\"arch-heading\" style=\"margin-bottom:1.25rem;\">\r\n          Reward Function\r\n        </div>\r\n        <div class=\"reward-table-wrap\">\r\n          <div class=\"reward-table-header\">\r\n            All 7 reward cases · applied every step\r\n          </div>\r\n          <div class=\"reward-row\">\r\n            <div class=\"rr-condition\">Energy drop &gt; 1.0 kcal/mol</div>\r\n            <div class=\"rr-val\" style=\"color:var(--teal);\">+8.0</div>\r\n            <div class=\"rr-bar\">\r\n              <div class=\"rr-bar-fill\"\r\n                   style=\"--w:100%;--c:var(--teal);\"></div>\r\n            </div>\r\n          </div>\r\n          <div class=\"reward-row\">\r\n            <div class=\"rr-condition\">RMSD &lt; 2Å vs native</div>\r\n            <div class=\"rr-val\" style=\"color:var(--teal);\">+15.0</div>\r\n            <div class=\"rr-bar\">\r\n              <div class=\"rr-bar-fill\"\r\n                   style=\"--w:100%;--c:var(--teal);\"></div>\r\n            </div>\r\n          </div>\r\n          <div class=\"reward-row\">\r\n            <div class=\"rr-condition\">Small energy drop</div>\r\n            <div class=\"rr-val\" style=\"color:var(--blue);\">+2.0</div>\r\n            <div class=\"rr-bar\">\r\n              <div class=\"rr-bar-fill\"\r\n                   style=\"--w:25%;--c:var(--blue);\"></div>\r\n            </div>\r\n          </div>\r\n          <div class=\"reward-row\">\r\n            <div class=\"rr-condition\">No steric clash</div>\r\n            <div class=\"rr-val\" style=\"color:var(--blue);\">+1.0</div>\r\n            <div class=\"rr-bar\">\r\n              <div class=\"rr-bar-fill\"\r\n                   style=\"--w:12%;--c:var(--blue);\"></div>\r\n            </div>\r\n          </div>\r\n          <div class=\"reward-row\">\r\n            <div class=\"rr-condition\">Per-step penalty</div>\r\n            <div class=\"rr-val\" style=\"color:var(--amber);\">−0.3</div>\r\n            <div class=\"rr-bar\">\r\n              <div class=\"rr-bar-fill\"\r\n                   style=\"--w:4%;--c:var(--amber);\"></div>\r\n            </div>\r\n          </div>\r\n          <div class=\"reward-row\">\r\n            <div class=\"rr-condition\">Energy increases</div>\r\n            <div class=\"rr-val\" style=\"color:var(--red);\">−1.0</div>\r\n            <div class=\"rr-bar\">\r\n              <div class=\"rr-bar-fill\"\r\n                   style=\"--w:12%;--c:var(--red);\"></div>\r\n            </div>\r\n          </div>\r\n          <div class=\"reward-row\">\r\n            <div class=\"rr-condition\">Steric clash detected</div>\r\n            <div class=\"rr-val\" style=\"color:var(--red);\">−2.0</div>\r\n            <div class=\"rr-bar\">\r\n              <div class=\"rr-bar-fill\"\r\n                   style=\"--w:25%;--c:var(--red);\"></div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n    </div>\r\n  </section>\r\n\r\n  <!-- ══════════════════════════════════════════\r\n       SECTION 5 — PPO\r\n  ══════════════════════════════════════════ -->\r\n  <section class=\"sci-section\">\r\n    <div class=\"section-label\">05 — PPO-clip · proximal policy optimisation</div>\r\n    <div class=\"ppo-grid\">\r\n\r\n      <div>\r\n        <div class=\"arch-heading\" style=\"margin-bottom:1.25rem;\">\r\n          Why PPO-clip?\r\n        </div>\r\n        <p class=\"arch-para\">\r\n          PPO-clip prevents catastrophic policy updates by\r\n          <strong>clipping the probability ratio</strong> between the\r\n          old and new policy. This ensures stable training even with\r\n          a high-dimensional, physics-driven reward signal.\r\n        </p>\r\n\r\n        <div class=\"eq-block\" style=\"border-left-color:var(--amber);\">\r\n          <div class=\"eq-label\">PPO-clip objective</div>\r\n          <div class=\"eq-formula\">\r\n            L = E[ min(r·A, clip(r, 1−ε, 1+ε)·A) ]\r\n          </div>\r\n          <div class=\"eq-desc\">\r\n            <span>r</span> = π_new / π_old ·\r\n            <span>A</span> = GAE advantage ·\r\n            <span>ε</span> = 0.2<br>\r\n            Clip prevents destructively large policy updates\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"eq-block\" style=\"border-left-color:var(--blue);\">\r\n          <div class=\"eq-label\">GAE advantage (λ=0.95)</div>\r\n          <div class=\"eq-formula\">\r\n            A_t = Σ (γλ)^k δ_{t+k}\r\n          </div>\r\n          <div class=\"eq-desc\">\r\n            <span>δ</span> = TD error ·\r\n            <span>γ</span> = 0.99 discount ·\r\n            <span>λ</span> = 0.95 bias-variance tradeoff<br>\r\n            Lower variance than Monte Carlo · lower bias than TD(0)\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div>\r\n        <div class=\"arch-heading\" style=\"margin-bottom:1.25rem;\">\r\n          Hyperparameters\r\n        </div>\r\n        <div class=\"ppo-params\">\r\n          <div class=\"ppo-param-row\">\r\n            <div class=\"pp-key\">Clip ε</div>\r\n            <div class=\"pp-val\">0.2</div>\r\n            <div class=\"pp-desc\">prevents large updates</div>\r\n          </div>\r\n          <div class=\"ppo-param-row\">\r\n            <div class=\"pp-key\">Discount γ</div>\r\n            <div class=\"pp-val\">0.99</div>\r\n            <div class=\"pp-desc\">long-horizon planning</div>\r\n          </div>\r\n          <div class=\"ppo-param-row\">\r\n            <div class=\"pp-key\">GAE λ</div>\r\n            <div class=\"pp-val\">0.95</div>\r\n            <div class=\"pp-desc\">bias-variance balance</div>\r\n          </div>\r\n          <div class=\"ppo-param-row\">\r\n            <div class=\"pp-key\">Horizon T</div>\r\n            <div class=\"pp-val\">256</div>\r\n            <div class=\"pp-desc\">steps per update</div>\r\n          </div>\r\n          <div class=\"ppo-param-row\">\r\n            <div class=\"pp-key\">Epochs</div>\r\n            <div class=\"pp-val\">4</div>\r\n            <div class=\"pp-desc\">updates per batch</div>\r\n          </div>\r\n          <div class=\"ppo-param-row\">\r\n            <div class=\"pp-key\">Entropy β</div>\r\n            <div class=\"pp-val\">0.01</div>\r\n            <div class=\"pp-desc\">exploration bonus</div>\r\n          </div>\r\n          <div class=\"ppo-param-row\">\r\n            <div class=\"pp-key\">Value coeff</div>\r\n            <div class=\"pp-val\">0.5</div>\r\n            <div class=\"pp-desc\">value loss weight</div>\r\n          </div>\r\n          <div class=\"ppo-param-row\">\r\n            <div class=\"pp-key\">Grad clip</div>\r\n            <div class=\"pp-val\">0.5</div>\r\n            <div class=\"pp-desc\">prevents explosion</div>\r\n          </div>\r\n          <div class=\"ppo-param-row\">\r\n            <div class=\"pp-key\">Learning rate</div>\r\n            <div class=\"pp-val\">3e-4</div>\r\n            <div class=\"pp-desc\">AdamW optimiser</div>\r\n          </div>\r\n          <div class=\"ppo-param-row\">\r\n            <div class=\"pp-key\">Reward norm</div>\r\n            <div class=\"pp-val\">ON</div>\r\n            <div class=\"pp-desc\">per-batch normalisation</div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n    </div>\r\n  </section>\r\n\r\n  <!-- ══════════════════════════════════════════\r\n       SECTION 6 — SCIENTIFIC JUSTIFICATION\r\n  ══════════════════════════════════════════ -->\r\n  <section class=\"sci-section\" style=\"border-bottom:none;\">\r\n    <div class=\"section-label\">\r\n      06 — scientific justification · judge questions answered\r\n    </div>\r\n    <div class=\"justify-grid\">\r\n      <div class=\"justify-card\" style=\"--ac:var(--blue);\">\r\n        <div class=\"justify-num\">Q1</div>\r\n        <div class=\"justify-title\">\r\n          Why simplified energy, not full MD?\r\n        </div>\r\n        <div class=\"justify-body\">\r\n          Full molecular dynamics takes <strong>hours per protein</strong>\r\n          on a supercomputer — incompatible with a real-time RL training loop\r\n          that runs thousands of steps per second.<br><br>\r\n          Our Lennard-Jones backbone potential captures the dominant forces\r\n          governing secondary structure formation. This is the same\r\n          approximation used in <strong>MARTINI coarse-grained models</strong>\r\n          — published in Nature Methods and used by research groups globally.\r\n          Scientifically justified. Computationally necessary.\r\n        </div>\r\n      </div>\r\n      <div class=\"justify-card\" style=\"--ac:var(--teal);\">\r\n        <div class=\"justify-num\">Q2</div>\r\n        <div class=\"justify-title\">\r\n          Can a hackathon project contribute anything real?\r\n        </div>\r\n        <div class=\"justify-body\">\r\n          We are not claiming to cure Alzheimer's in 36 hours.\r\n          We are demonstrating that <strong>RL with a physics-based reward\r\n          is a viable framework</strong> for exploring folding pathways —\r\n          never demonstrated in an open, accessible way before.<br><br>\r\n          AlphaFold itself began as a proof of concept at a CASP competition.\r\n          Every major breakthrough starts as a demonstration the approach works.\r\n          <strong>This is ours.</strong>\r\n        </div>\r\n      </div>\r\n      <div class=\"justify-card\" style=\"--ac:var(--amber);\">\r\n        <div class=\"justify-num\">Q3</div>\r\n        <div class=\"justify-title\">\r\n          Why GNN and not a simpler model?\r\n        </div>\r\n        <div class=\"justify-body\">\r\n          Proteins are graphs — residues connected by covalent bonds\r\n          and spatial contacts. A flat MLP treats the protein as an\r\n          unordered feature vector and loses all structural information.<br><br>\r\n          <strong>GNNs are the natural architecture</strong> for\r\n          graph-structured data. Message passing propagates local chemical\r\n          information across the full protein topology — exactly what is\r\n          needed to make spatially-aware folding decisions.\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </section>\r\n\r\n  <!-- ══ PASS BADGE ══ -->\r\n  <div class=\"pass-row\">\r\n    <div class=\"pass-dot\"></div>\r\n    <div class=\"pass-text\">\r\n      GNN + PPO-clip · Lennard-Jones potential · NeRF kinematics ·\r\n      MARTINI-justified coarse-graining · physics is the teacher ✓\r\n    </div>\r\n  </div>\r\n\r\n  <!-- ══ FOOTER ══ -->\r\n  <footer class=\"footer\">\r\n    <div class=\"footer-l\">\r\n      ProteinFold-RL · NIT Delhi · Open Innovation Track · 2025\r\n    </div>\r\n    <div class=\"footer-r\">science.html · page 4 of 5</div>\r\n  </footer>\r\n\r\n</div>\r\n\r\n<script src=\"assets/js/stars.js\"></script>\r\n<script src=\"assets/js/ticker.js\"></script>\r\n<script>\r\n  initStarfield();\r\n  initTicker();\r\n</script>\r\n\r\n</body>\r\n</html>
