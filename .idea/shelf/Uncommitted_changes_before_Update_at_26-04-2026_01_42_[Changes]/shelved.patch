══════════════════════════════ */\r\n    .rl-diagram-wrap {\r\n      background: var(--bg2);\r\n      border: 0.5px solid var(--border);\r\n      padding: 2rem;\r\n      overflow-x: auto;\r\n    }\r\n    .rl-diagram-label {\r\n      font-family: var(--mono);\r\n      font-size: 9px;\r\n      letter-spacing: 0.18em;\r\n      text-transform: uppercase;\r\n      color: rgba(61,159,255,0.35);\r\n      margin-bottom: 1.5rem;\r\n    }\r\n\r\n    /* ══════════════════════════════════════════\r\n       GNN ARCHITECTURE — SPLIT\r\n    ══════════════════════════════════════════ */\r\n    .arch-grid {\r\n      display: grid;\r\n      grid-template-columns: 1fr 1fr;\r\n      gap: 2rem;\r\n      align-items: start;\r\n    }\r\n    .arch-visual {\r\n      background: var(--bg2);\r\n      border: 0.5px solid var(--border);\r\n      padding: 1.5rem;\r\n    }\r\n    .arch-text {}\r\n    .arch-heading {\r\n      font-size: 1.2rem;\r\n      font-weight: 800;\r\n      color: #eaf4ff;\r\n      margin-bottom: 0.75rem;\r\n      letter-spacing: -0.01em;\r\n    }\r\n    .arch-para {\r\n      font-family: var(--mono);\r\n      font-size: 11px;\r\n      color: var(--text-dim);\r\n      line-height: 2;\r\n      margin-bottom: 1rem;\r\n    }\r\n    .arch-para strong { color: var(--blue); }\r\n    .arch-para em     { color: var(--teal); font-style: normal; }\r\n\r\n    .arch-table {\r\n      width: 100%;\r\n      border-collapse: collapse;\r\n      font-family: var(--mono);\r\n      font-size: 10px;\r\n      margin-top: 1rem;\r\n    }\r\n    .arch-table tr {\r\n      border-bottom: 0.5px solid var(--border);\r\n    }\r\n    .arch-table tr:last-child { border-bottom: none; }\r\n    .arch-table td {\r\n      padding: 0.6rem 0.75rem;\r\n      color: var(--text-dim);\r\n      vertical-align: top;\r\n    }\r\n    .arch-table td:first-child {\r\n      color: var(--blue);\r\n      font-weight: 700;\r\n      width: 120px;\r\n      letter-spacing: 0.06em;\r\n    }\r\n    .arch-table td:last-child { color