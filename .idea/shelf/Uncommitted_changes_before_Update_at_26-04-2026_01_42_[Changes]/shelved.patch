ttom: 2rem;\r\n    }\r\n\r\n    .hero-sub {\r\n      font-family: var(--mono);\r\n      font-size: 12px;\r\n      line-height: 2;\r\n      color: var(--text-dim);\r\n      margin-bottom: 2.5rem;\r\n      max-width: 440px;\r\n    }\r\n    .hero-sub strong { color: var(--text-mid); }\r\n\r\n    .cta-row { display: flex; gap: 12px; align-items: center; }\r\n\r\n    /* ── Protein Visual ── */\r\n    .hero-right {\r\n      display: flex;\r\n      flex-direction: column;\r\n      align-items: center;\r\n      justify-content: center;\r\n      gap: 1rem;\r\n      padding: 2rem;\r\n      border-left: 0.5px solid var(--border);\r\n      height: 100%;\r\n    }\r\n    .protein-label {\r\n      font-family: var(--mono);\r\n      font-size: 9px;\r\n      letter-spacing: 0.18em;\r\n      color: rgba(61,159,255,0.35);\r\n      text-transform: uppercase;\r\n      text-align: center;\r\n    }\r\n    .helix-svg { width: 260px; }\r\n\r\n    /* ── Hero bottom strip ── */\r\n    .hero-strip {\r\n      grid-column: 1 / -1;\r\n      display: grid;\r\n      grid-template-columns: repeat(4, 1fr);\r\n      border-top: 0.5px solid var(--border);\r\n      margin-top: 2rem;\r\n    }\r\n    .hero-strip-item {\r\n      padding: 1.25rem 1.5rem;\r\n      border-right: 0.5px solid var(--border);\r\n      display: flex;\r\n      flex-direction: column;\r\n      gap: 4px;\r\n    }\r\n    .hero-strip-item:last-child { border-right: none; }\r\n    .strip-val {\r\n      font-size: 1.5rem;\r\n      font-weight: 800;\r\n      color: #eaf4ff;\r\n      line-height: 1;\r\n    }\r\n    .strip-val .t { color: var(--teal); }\r\n    .strip-val .b { color: var(--blue); }\r\n    .strip-lbl {\r\n      font-family: var(--mono);\r\n      font-size: 9px;\r\n      letter-spacing: 0.12em;\r\n      text-transform: uppercase;\r\n      color: var(--text-dim);\r\n    }\r\n\r\n    /* ══════════════════════════════════════════\r\n       TICKER\r\n    ══════════════════════════════════════════ */\r\n    /* (from design-system.css) */\r\n\r\n    /* ══════════════════════════════════════════\r\n       SECTIONS\r\n    ══════════════════════════════════════════ */\r\n    .section { padding: 3.5rem 2.5rem; }\r\n    .section + .section { border-top: 0.5px solid var(--border); }\r\n\r\n    /* ══════════════════════════════════════════\r\n       RL LOOP\r\n    ══════════════════════════════════════════ */\r\n    .loop-grid {\r\n      display: grid;\r\n      grid-template-columns: repeat(4, 1fr);\r\n      border: 0.5px solid var(--border);\r\n    }\r\n    .loop-card {\r\n      padding: 1.75rem 1.5rem;\r\n      border-right: 0.5px solid var(--border);\r\n      background: var(--bg2);\r\n      position: relative;\r\n      transition: background 0.2s;\r\n    }\r\n    .loop-card:last-child { border-right: none; }\r\n    .loop-card:hover { background: var(--bg3); }\r\n    .loop-top-bar {\r\n      position: absolute;\r\n      top: 0; left: 0; right: 0;\r\n      height: 2px;\r\n      background: var(--ac);\r\n    }\r\n    .loop-idx {\r\n      font-family: var(--mono);\r\n      font-size: 9px;\r\n      letter-spacing: 0.14em;\r\n      color: var(--text-dim);\r\n      margin-bottom: 0.75rem;\r\n      text-transform: uppercase;\r\n      margin-top: 0.5rem;\r\n    }\r\n    .loop-title {\r\n      font-size: 1.05rem;\r\n      font-weight: 700;\r\n      color: #eaf4ff;\r\n      margin-bottom: 1rem;\r\n      padding-bottom: 0.75rem;\r\n      border-bottom: 0.5px solid var(--border);\r\n    }\r\n    .loop-row {\r\n      display: flex;\r\n      align-items: baseline;\r\n      gap: 8px;\r\n      margin-bottom: 6px;\r\n    }\r\n    .loop-key {\r\n      font-family: var(--mono);\r\n      font-size: 9px;\r\n      color: var(--text-dim);\r\n      letter-spacing: 0.08em;\r\n      flex-shrink: 0;\r\n    }\r\n    .loop-val {\r\n      font-family: var(--mono);\r\n      font-size: 10px;\r\n      font-weight: 700;\r\n      letter-spacing: 0.04em;\r\n    }\r\n    .c-b { color: var(--blue); }\r\n    .c-t { color: var(--teal); }\r\n    .c-r { color: var(--red); }\r\n    .c-a { color: var(--amber); }\r\n    .c-w { color: var(--text-mid); }\r\n\r\n    /* ══════════════════════════════════════════\r\n       COMPARISON\r\n    ══════════════════════════════════════════ */\r\n    .cmp-grid {\r\n      display: grid;\r\n      grid-template-columns: 1fr 1fr;\r\n      gap: 1px;\r\n      background: var(--border);\r\n      border: 0.5px solid var(--border);\r\n    }\r\n    .cmp-card {\r\n      padding: 2rem;\r\n      background: var(--bg2);\r\n    }\r\n    .cmp-header {\r\n      display: flex;\r\n      align-items: center;\r\n      justify-content: space-between;\r\n      margin-bottom: 1.5rem;\r\n    }\r\n    .cmp-title {\r\n      font-family: var(--mono);\r\n      font-size: 9px;\r\n      letter-spacing: 0.14em;\r\n      text-transform: uppercase;\r\n      color: var(--text-dim);\r\n    }\r\n    .cmp-badge {\r\n      font-family: var(--mono);\r\n      font-size: 9px;\r\n      padding: 3px 8px;\r\n      border: 0.5px solid rgba(61,159,255,0.2);\r\n      color: var(--blue);\r\n      letter-spacing: 0.08em;\r\n    }\r\n\r\n    .bar-group { margin-bottom: 1.5rem; }\r\n    .bar-row {\r\n      display: flex;\r\n      align-items: center;\r\n      gap: 12px;\r\n      margin-bottom: 8px;\r\n    }\r\n    .bar-name {\r\n      font-family: var(--mono);\r\n      font-size: 9px;\r\n      color: var(--text-dim);\r\n      width: 50px;\r\n      text-align: right;\r\n      flex-shrink: 0;\r\n      text-transform: uppercase;\r\n      letter-spacing: 0.06em;\r\n    }\r\n    .bar-track {\r\n      flex: 1;\r\n      height: 6px;\r\n      background: rgba(61,159,255,0.06);\r\n      position: relative;\r\n    }\r\n    .bar-fill {\r\n      position: absolute;\r\n      top: 0; left: 0; bottom: 0;\r\n      width: 0;\r\n      animation: bar-grow 1.6s ease forwards;\r\n      animation-delay: 0.4s;\r\n    }\r\n    @keyframes bar-grow { to { width: var(--w); } }\r\n    .bar-val {\r\n      font-family: var(--mono);\r\n      font-size: 10px;\r\n      font-weight: 700;\r\n      color: var(--text-mid);\r\n      width: 60px;\r\n      flex-shrink: 0;\r\n    }\r\n\r\n    .cmp-result {\r\n      padding-top: 1.25rem;\r\n      border-top: 0.5px solid var(--border);\r\n      display: flex;\r\n      align-items: baseline;\r\n      gap: 12px;\r\n    }\r\n    .cmp-big {\r\n      font-size: 2.2rem;\r\n      font-weight: 800;\r\n      color: var(--teal);\r\n      line-height: 1;\r\n    }\r\n    .cmp-sub {\r\n      font-family: var(--mono);\r\n      font-size: 10px;\r\n      color: rgba(0,212,170,0.5);\r\n    }\r\n\r\n    /* ══════════════════════════════════════════\r\n       STACK\r\n    ══════════════════════════════════════════ */\r\n    .stack-grid {\r\n      display: grid;\r\n      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));\r\n      gap: 1px;\r\n      background: var(--border);\r\n      border: 0.5px solid var(--border);\r\n    }\r\n    .stack-item {\r\n      background: var(--bg2);\r\n      padding: 1rem 1.25rem;\r\n      display: flex;\r\n      flex-direction: column;\r\n      gap: 4px;\r\n      transition: background 0.15s;\r\n    }\r\n    .stack-item:hover { background: var(--bg3); }\r\n    .stack-name {\r\n      font-family: var(--mono);\r\n      font-size: 11px;\r\n      font-weight: 700;\r\n      color: var(--text-mid);\r\n      letter-spacing: 0.04em;\r\n    }\r\n    .stack-role {\r\n      font-family: var(--mono);\r\n      font-size: 9px;\r\n      color: var(--text-dim);\r\n      letter-spacing: 0.08em;\r\n    }\r\n\r\n    /* ══════════════════════════════════════════\r\n       RESPONSIVE\r\n    ══════════════════════════════════════════ */\r\n    @media (max-width: 960px) {\r\n      .hero {\r\n        grid-template-columns: 1fr;\r\n        min-height: auto;\r\n        padding: 2.5rem 1.5rem;\r\n      }\r\n      .hero-right { display: none; }\r\n      .hero-strip { grid-template-columns: 1fr 1fr; }\r\n      .hero-h1, .hero-h1-second { font-size: 2.4rem; }\r\n      .loop-grid { grid-template-columns: 1fr 1fr; }\r\n      .cmp-grid  { grid-template-columns: 1fr; }\r\n      .section   { padding: 2.5rem 1.5rem; }\r\n    }\r\n    @media (max-width: 560px) {\r\n      .hero-h1, .hero-h1-second { font-size: 1.9rem; }\r\n      .hero-strip { grid-template-columns: 1fr 1fr; }\r\n      .loop-grid  { grid-template-columns: 1fr; }\r\n    }\r\n  </style>\r\n</head>\r\n<body>\r\n\r\n<canvas id=\"stars-canvas\"></canvas>\r\n\r\n<div class=\"page\">\r\n\r\n  <!-- ══ NAV ══ -->\r\n  <nav class=\"nav\">\r\n    <a class=\"nav-logo\" href=\"index.html\">\r\n      <div class=\"nav-logo-dot\"></div>\r\n      PROTEINFOLD-RL\r\n    </a>\r\n    <ul class=\"nav-links\">\r\n      <a href=\"index.html\"     class=\"active\">Home</a>\r\n      <a href=\"dashboard.html\"              >Dashboard</a>\r\n      <a href=\"demo.html\"                   >Live Demo</a>\r\n      <a href=\"science.html\"                >Science</a>\r\n      <a href=\"compare.html\"                >Compare</a>\r\n    </ul>\r\n    <div class=\"nav-right\"></div>\r\n  </nav>\r\n\r\n  <!-- ══ HERO ══ -->\r\n  <section class=\"hero\">\r\n\r\n    <!-- Left: text -->\r\n    <div class=\"hero-left\">\r\n      <div class=\"hero-eyebrow\">\r\n        Reinforcement Learning + Graph Neural Networks · Computational Biology\r\n      </div>\r\n\r\n      <h1 class=\"hero-h1\">\r\n        AlphaFold shows the <span class=\"hl\">destination.</span>\r\n      </h1>\r\n      <h2 class=\"hero-h1-second\">\r\n        We discover the <span class=\"hl\">journey.</span>\r\n      </h2>\r\n\r\n      <div class=\"hero-divider\"></div>\r\n\r\n      <p class=\"hero-sub\">\r\n        An RL agent that learns <strong>how proteins fold</strong> —\r\n        not where they end up.<br>\r\n        Rewarded by the laws of chemistry. No human labels.<br>\r\n        <strong>Physics is the teacher.</strong>\r\n      </p>\r\n\r\n      <div class=\"cta-row\">\r\n        <a class=\"btn-primary\" href=\"dashboard.html\">View Dashboard</a>\r\n        <a class=\"btn-ghost\"   href=\"science.html\">How it works ↗</a>\r\n      </div>\r\n\r\n      <!-- Stats strip inside hero -->\r\n      <div class=\"hero-strip\">\r\n        <div class=\"hero-strip-item\">\r\n          <div class=\"strip-val\"><span class=\"t\">15.920</span> Å</div>\r\n          <div class=\"strip-lbl\">Trained avg RMSD</div>\r\n        </div>\r\n        <div class=\"hero-strip-item\">\r\n          <div class=\"strip-val\"><span class=\"b\">+62.8</span> kcal</div>\r\n          <div class=\"strip-lbl\">Energy gain</div>\r\n        </div>\r\n        <div class=\"hero-strip-item\">\r\n          <div class=\"strip-val\">500</div>\r\n          <div class=\"strip-lbl\">Episodes</div>\r\n        </div>\r\n        <div class=\"hero-strip-item\">\r\n          <div class=\"strip-val\"><span class=\"t\">−5.1%</span></div>\r\n          <div class=\"strip-lbl\">RMSD vs random</div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- Right: protein illustration -->\r\n    <div class=\"hero-right\">\r\n      <div class=\"protein-label\">Trp-cage · 1L2Y · 20 residues</div>\r\n      <svg class=\"helix-svg\" viewBox=\"0 0 260 460\" fill=\"none\"\r\n           xmlns=\"http://www.w3.org/2000/svg\">\r\n        <!-- Alpha helix -->\r\n        <text x=\"20\" y=\"28\" font-family=\"Space Mono,monospace\"\r\n              font-size=\"8\" fill=\"rgba(61,159,255,0.45)\"\r\n              letter-spacing=\"2\">α-HELIX</text>\r\n        <g opacity=\"0.85\">\r\n          <ellipse cx=\"130\" cy=\"55\"  rx=\"50\" ry=\"13\"\r\n                   stroke=\"#3d9fff\" stroke-width=\"1.2\" opacity=\"0.7\"/>\r\n          <ellipse cx=\"130\" cy=\"82\"  rx=\"54\" ry=\"13\"\r\n                   stroke=\"#3d9fff\" stroke-width=\"1.2\" opacity=\"0.62\"/>\r\n          <ellipse cx=\"130\" cy=\"109\" rx=\"52\" ry=\"13\"\r\n                   stroke=\"#3d9fff\" stroke-width=\"1.2\" opacity=\"0.54\"/>\r\n          <ellipse cx=\"130\" cy=\"136\" rx=\"50\" ry=\"13\"\r\n                   stroke=\"#3d9fff\" stroke-width=\"1.2\" opacity=\"0.46\"/>\r\n          <ellipse cx=\"130\" cy=\"163\" rx=\"52\" ry=\"13\"\r\n                   stroke=\"#3d9fff\" stroke-width=\"1.2\" opacity=\"0.38\"/>\r\n          <line x1=\"78\"  y1=\"55\" x2=\"78\"  y2=\"163\"\r\n                stroke=\"#3d9fff\" stroke-width=\"0.7\" opacity=\"0.2\"/>\r\n          <line x1=\"182\" y1=\"55\" x2=\"182\" y2=\"163\"\r\n                stroke=\"#3d9fff\" stroke-width=\"0.7\" opacity=\"0.2\"/>\r\n        </g>\r\n\r\n        <!-- Beta sheet -->\r\n        <text x=\"20\" y=\"218\" font-family=\"Space Mono,monospace\"\r\n              font-size=\"8\" fill=\"rgba(61,159,255,0.45)\"\r\n              letter-spacing=\"2\">β-SHEET</text>\r\n        <g opacity=\"0.62\">\r\n          <rect x=\"50\" y=\"226\" width=\"160\" height=\"10\" rx=\"2\"\r\n                fill=\"rgba(20,70,130,0.6)\" stroke=\"#3d9fff\" stroke-width=\"0.6\"/>\r\n          <rect x=\"50\" y=\"248\" width=\"160\" height=\"10\" rx=\"2\"\r\n                fill=\"rgba(20,70,130,0.6)\" stroke=\"#3d9fff\" stroke-width=\"0.6\"/>\r\n          <rect x=\"50\" y=\"270\" width=\"160\" height=\"10\" rx=\"2\"\r\n                fill=\"rgba(20,70,130,0.6)\" stroke=\"#3d9fff\" stroke-width=\"0.6\"/>\r\n          <polygon points=\"210,222 226,231 210,240\"\r\n                   fill=\"#3d9fff\" opacity=\"0.75\"/>\r\n          <polygon points=\"210,244 226,253 210,262\"\r\n                   fill=\"#3d9fff\" opacity=\"0.75\"/>\r\n          <polygon points=\"210,266 226,275 210,284\"\r\n                   fill=\"#3d9fff\" opacity=\"0.75\"/>\r\n        </g>\r\n\r\n        <!-- Loop -->\r\n        <text x=\"20\" y=\"340\" font-family=\"Space Mono,monospace\"\r\n              font-size=\"8\" fill=\"rgba(61,159,255,0.45)\"\r\n              letter-spacing=\"2\">LOOP</text>\r\n        <path d=\"M130 298 Q96 318 114 342 Q152 366 130 390\"\r\n              stroke=\"#3d9fff\" stroke-width=\"1.3\" fill=\"none\"\r\n              stroke-